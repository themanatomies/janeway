# deployment/.env.prod.example
# Production Environment Configuration for djourns.com
# Copy to .env.prod and update with actual values
# Never commit .env.prod to version control

# Django Settings
DEBUG=False
DJANGO_SETTINGS_MODULE=janeway.settings
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_MINIMUM_50_CHARS

# Database Configuration
DATABASE_ENGINE=django.db.backends.postgresql
DB_NAME=janeway
DB_USER=janeway
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_HOST=postgres
DB_PORT=5432

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=press.djourns.com,anotherpress.djourns.com,www.djourns.com

# Email Configuration (Postfix on droplet)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@djourns.com

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# SSL/HTTPS Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Press Configuration (multi-press)
INSTALLED_APPS_LOCAL=

# AWS S3 Configuration (optional - for backups/media)
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# Backup Configuration
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=14
BACKUP_LOCATION=/vol/janeway/backups

# Logging
LOG_LEVEL=INFO
